/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_SPI2_Init();
  /* USER CODE BEGIN 2 */

  uint8_t txData[3];
  uint8_t rxData[3];

  // --- RESET ---
  txData[0] = 0xC0;

  HAL_GPIO_WritePin(GPIOB, CS_Pin, GPIO_PIN_RESET);
  HAL_Delay(1);
  HAL_SPI_TransmitReceive(&hspi2, &txData[0], &rxData[0], 1, HAL_MAX_DELAY);
  HAL_GPIO_WritePin(GPIOB, CS_Pin, GPIO_PIN_SET);

  HAL_Delay(10);  // Give MCP25625 time to reset

  // --- READ CANSTAT (address 0x0E) ---
  txData[0] = 0x03;  // READ command
  txData[1] = 0x0E;  // CANSTAT register address
  txData[2] = 0x00;  // Dummy byte to clock in response

  HAL_GPIO_WritePin(GPIOB, CS_Pin, GPIO_PIN_RESET); // CS LOW
  HAL_Delay(1);

  HAL_SPI_TransmitReceive(&hspi2, &txData[0], &rxData[0], 1, HAL_MAX_DELAY); // READ cmd
  HAL_SPI_TransmitReceive(&hspi2, &txData[1], &rxData[1], 1, HAL_MAX_DELAY); // Address
  HAL_SPI_TransmitReceive(&hspi2, &txData[2], &rxData[2], 1, HAL_MAX_DELAY); // Dummy

  HAL_GPIO_WritePin(GPIOB, CS_Pin, GPIO_PIN_SET);   // CS HIGH



  // rxData[2] contains CANSTAT value
  // Expected: 0x80 = Configuration Mode
  uint8_t canstat = rxData[2];

  if (canstat&0x80)
  {
      HAL_GPIO_WritePin(GPIOA, LED_Panic_Pin, GPIO_PIN_RESET); // Turn off panic LED
  }
  else
  {
      HAL_GPIO_WritePin(GPIOA, LED_Panic_Pin, GPIO_PIN_SET);   // Turn on panic LED
  }


  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
	  HAL_GPIO_TogglePin(GPIOA, Pwr_Indicator_Pin);
	  HAL_Delay(500);

	  //***********FAN**************
      HAL_GPIO_WritePin(GPIOB, FAN_PWM_IN_Pin, GPIO_PIN_RESET);   // turn on fan
      HAL_Delay(1000);
      HAL_GPIO_WritePin(GPIOB, FAN_PWM_IN_Pin, GPIO_PIN_SET);   // turn off fan
      HAL_Delay(1000);
	  //***********FAN**************




  }
  /* USER CODE END 3 */
}

