void PWR_ON_OFF(void){
	HAL_GPIO_WritePin(GPIOB, ORIN_PWR_CTL_Pin, GPIO_PIN_SET);
	HAL_Delay(1);
	HAL_GPIO_WritePin(GPIOB, ORIN_PWR_CTL_Pin, GPIO_PIN_RESET);

}
int Jetson_Boot_Monitor(void){
	if (HAL_GPIO_ReadPin(GPIOB, VMON_JETSON_BOOT_Pin) == GPIO_PIN_SET){
		return 1;
	}
	else
		return 0;
}
void Jetson_Shut_Down(void){
	int status=0;
	HAL_GPIO_WritePin(GPIOD, ORIN_PWR_SHDNREQ_Pin, GPIO_PIN_SET);//Signals to Python script
	HAL_Delay(2);

	status=Jetson_Boot_Monitor();
	if(status){
		HAL_GPIO_WritePin(GPIOB, ORIN_PWR_CTL_Pin, GPIO_PIN_SET);//Short press
		HAL_Delay(1);
		HAL_GPIO_WritePin(GPIOB, ORIN_PWR_CTL_Pin, GPIO_PIN_RESET);

		status=Jetson_Boot_Monitor();

	}
	else
		return;
	while(status){
		HAL_GPIO_WritePin(GPIOB, ORIN_PWR_CTL_Pin, GPIO_PIN_SET);//Long press

	}
	return;
}

void set_bit_timing(void){

	/*MCP25625_WriteReg(0x2A, 0x00);
	MCP25625_WriteReg(0x29, 0xA1);
	MCP25625_WriteReg(0x28, 0x03);*/

	uint8_t txData[3];
	uint8_t rxData[3];

	// --- WRITE to CNF1 register (0x2A) ---
	txData[0] = 0x02;  // WRITE command
	txData[1] = 0x2A;  // CNF1 register address
	txData[2] = 0x00;  // Value to write

	HAL_GPIO_WritePin(GPIOB, CS_Pin, GPIO_PIN_RESET); // CS LOW

	HAL_SPI_TransmitReceive(&hspi2, &txData[0], &rxData[0], 1, HAL_MAX_DELAY); // WRITE cmd
	HAL_SPI_TransmitReceive(&hspi2, &txData[1], &rxData[1], 1, HAL_MAX_DELAY); // Address
	HAL_SPI_TransmitReceive(&hspi2, &txData[2], &rxData[2], 1, HAL_MAX_DELAY); // Data

	HAL_GPIO_WritePin(GPIOB, CS_Pin, GPIO_PIN_SET);   // CS HIGH

	// --- READ back CNF1 (0x2A) ---
	txData[0] = 0x03;  // READ command
	txData[1] = 0x2A;  // CNF1 register address
	txData[2] = 0x00;  // Dummy byte

	HAL_GPIO_WritePin(GPIOB, GPIO_PIN_12, GPIO_PIN_RESET); // CS LOW

	HAL_SPI_TransmitReceive(&hspi2, &txData[0], &rxData[0], 1, HAL_MAX_DELAY);
	HAL_SPI_TransmitReceive(&hspi2, &txData[1], &rxData[1], 1, HAL_MAX_DELAY);
	HAL_SPI_TransmitReceive(&hspi2, &txData[2], &rxData[2], 1, HAL_MAX_DELAY);

	HAL_GPIO_WritePin(GPIOB, GPIO_PIN_12, GPIO_PIN_SET);   // CS HIGH

	////////////////////////////////////////////////


	// --- WRITE 0xA1 to register 0x29 ---
	/*txData[0] = 0x02;  // WRITE command
	txData[1] = 0x29;  // Register address
	txData[2] = 0xA1;  // Value to write

	HAL_GPIO_WritePin(GPIOB, GPIO_PIN_12, GPIO_PIN_RESET); // CS LOW

	HAL_SPI_TransmitReceive(&hspi2, &txData[0], &rxData[0], 1, HAL_MAX_DELAY); // WRITE cmd
	HAL_SPI_TransmitReceive(&hspi2, &txData[1], &rxData[1], 1, HAL_MAX_DELAY); // Address
	HAL_SPI_TransmitReceive(&hspi2, &txData[2], &rxData[2], 1, HAL_MAX_DELAY); // Data

	HAL_GPIO_WritePin(GPIOB, GPIO_PIN_12, GPIO_PIN_SET);   // CS HIGH*/

	uint8_t cnf1 = rxData[2];  // Should be 0x00 if write succeeded

	if (cnf1==0xA1){
		HAL_GPIO_WritePin(GPIOA, LED_Panic_Pin, GPIO_PIN_RESET); // Turn off panic LED

	}
	else{
		HAL_GPIO_WritePin(GPIOA, LED_Panic_Pin, GPIO_PIN_SET); // Turn on panic LED
		HAL_Delay(100);
		HAL_GPIO_WritePin(GPIOA, LED_Panic_Pin, GPIO_PIN_RESET); // Turn off panic LED



	}

}
uint8_t MCP_READ(uint8_t addr){
	uint8_t txData[3]={0x03, addr,0x00};
	uint8_t rxData[3]={0};


	CS_LOW(); // CS LOW

	HAL_SPI_TransmitReceive(&hspi2, &txData[0], &rxData[0], 1, HAL_MAX_DELAY); // READ cmd
	HAL_SPI_TransmitReceive(&hspi2, &txData[1], &rxData[1], 1, HAL_MAX_DELAY); // Address
	HAL_SPI_TransmitReceive(&hspi2, &txData[2], &rxData[2], 1, HAL_MAX_DELAY); // Dummy

	CS_HIGH();   // CS HIGH
	return rxData[2];
}

void MCP_write (uint8_t address, uint8_t value)
{

    uint8_t tx[3] = {0x02, address, value };

    CS_LOW();
    (void)HAL_SPI_Transmit(&hspi2, tx, 3, HAL_MAX_DELAY);
    CS_HIGH();
}

void MCP_bit_modify(uint8_t address, uint8_t mask, uint8_t data)
{

    uint8_t tx[4] = { 0x05, address, mask, data };

    CS_LOW();
    (void)HAL_SPI_Transmit(&hspi2, tx, 4, HAL_MAX_DELAY);
    CS_HIGH();
}

void MCP_reset(void){
	uint8_t cmd=0xC0;
	CS_LOW();
	(void)HAL_SPI_Transmit(&hspi2, &cmd, 1, HAL_MAX_DELAY);
	CS_HIGH();
}

bool MCP_init(void) {


	MCP_reset();

	if (!(MCP_READ(0x0E)&0x80)) {
		return false;
	}

	MCP_write(0x2A, 0xC0);//CNF1
	MCP_write(0x29, 0x9E);//CNF2
	MCP_write(0x28, 0x03);//CNF3

	MCP_bit_modify(0x0F, 0xE0, 0x00); //Set normal mode in canctrl

	HAL_Delay(2);

	if (MCP_READ(0x0E)!=0x00) {
		return false;
	}

	return true;


}
